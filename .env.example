# ---- Base de datos (Prisma Postgres en Vercel) ----
# Este valor lo genera Vercel automáticamente al conectar la base de datos
# "Prisma Postgres" desde la pestaña Storage de tu proyecto. Para desarrollo
# local, lo obtienes corriendo: vercel env pull .env.local
# Ya incluye connection pooling, no necesitas parámetros extra.
DATABASE_URL="postgres://usuario:password@host.prisma-data.net:5432/nombre_bd?sslmode=require"

# ---- Autenticación ----
# Genera un secreto largo y aleatorio, ej: openssl rand -base64 32
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# ---- WhatsApp Cloud API (Meta) ----
# Token permanente del System User (ver README para generarlo)
WHATSAPP_TOKEN="EAAG..."
# Phone Number ID (Meta for Developers > WhatsApp > API Setup)
WHATSAPP_PHONE_NUMBER_ID="1234567890"
# WhatsApp Business Account ID (WABA ID)
WHATSAPP_BUSINESS_ACCOUNT_ID="1234567890"
# Token que TÚ inventas y usas para verificar el webhook en Meta (cualquier string seguro)
WHATSAPP_VERIFY_TOKEN="elige-un-token-secreto-para-verificar-el-webhook"
# Versión de la Graph API que estás usando
WHATSAPP_API_VERSION="v20.0"
